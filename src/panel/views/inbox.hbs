<div class="page-layout">
  <!-- LEFT PANEL: Conversation List -->
  <div class="panel panel-left conversation-list">
    <div class="conversation-list-header">
      <h1 class="conversation-list-title">Inbox</h1>
      <input
        type="text"
        class="conversation-search"
        placeholder="Buscar conversación..."
        aria-label="Search conversations"
      />
    </div>

    <!-- Operational Summary -->
    {{#if operationalSummary}}
    <div class="operational-summary">
      <div class="operational-summary-text">{{operationalSummary}}</div>
    </div>
    {{/if}}

    <!-- Grouped Conversations -->
    {{#if groupedConversations}}

    <!-- Attention Required Group -->
    {{#if groupedConversations.attentionRequired}}
    <div class="conversation-group">
      <div class="group-header">
        <span class="group-icon">⚠️</span>
        <span class="group-title">Requiere Atención</span>
        <span class="group-count">{{groupedConversations.attentionRequired.length}}</span>
      </div>
      <div class="group-conversations">
        {{#each groupedConversations.attentionRequired}}
        <div class="conversation-card attention-required">
          <div class="card-header">
            <div class="card-contact-name {{#if (eq this.contactName this.contactPhone)}}unnamed{{/if}}">
              {{this.contactName}}
            </div>
            <time class="card-timestamp">{{ago this.lastMessageTime}}</time>
          </div>

          <div class="card-metadata">
            <span class="card-phone">{{this.contactPhone}}</span>
            <span class="card-divider">·</span>
            <span class="card-msg-count">{{this.messageCount}} msgs</span>
          </div>

          <div class="card-message">{{truncate this.lastMessage 100}}</div>

          <div class="card-status attention-required">
            <span class="status-indicator attention-required"></span>
            <span>Esperando respuesta (6+ horas)</span>
          </div>
        </div>
        {{else}}
        <div class="group-empty">No hay conversaciones requiriendo atención</div>
        {{/each}}
      </div>
    </div>
    {{/if}}

    <!-- Waiting Client Group -->
    {{#if groupedConversations.waitingClient}}
    <div class="conversation-group">
      <div class="group-header">
        <span class="group-icon">👤</span>
        <span class="group-title">Esperando Cliente</span>
        <span class="group-count">{{groupedConversations.waitingClient.length}}</span>
      </div>
      <div class="group-conversations">
        {{#each groupedConversations.waitingClient}}
        <div class="conversation-card waiting-client">
          <div class="card-header">
            <div class="card-contact-name {{#if (eq this.contactName this.contactPhone)}}unnamed{{/if}}">
              {{this.contactName}}
            </div>
            <time class="card-timestamp">{{ago this.lastMessageTime}}</time>
          </div>

          <div class="card-metadata">
            <span class="card-phone">{{this.contactPhone}}</span>
            <span class="card-divider">·</span>
            <span class="card-msg-count">{{this.messageCount}} msgs</span>
          </div>

          <div class="card-message">{{truncate this.lastMessage 100}}</div>

          <div class="card-status waiting-client">
            <span class="status-indicator waiting-client"></span>
            <span>Listo para revisar</span>
          </div>
        </div>
        {{else}}
        <div class="group-empty">No hay conversaciones esperando cliente</div>
        {{/each}}
      </div>
    </div>
    {{/if}}

    <!-- In Attention Group -->
    {{#if groupedConversations.inAttention}}
    <div class="conversation-group">
      <div class="group-header">
        <span class="group-icon">🔄</span>
        <span class="group-title">En Captura</span>
        <span class="group-count">{{groupedConversations.inAttention.length}}</span>
      </div>
      <div class="group-conversations">
        {{#each groupedConversations.inAttention}}
        <div class="conversation-card in-attention">
          <div class="card-header">
            <div class="card-contact-name {{#if (eq this.contactName this.contactPhone)}}unnamed{{/if}}">
              {{this.contactName}}
            </div>
            <time class="card-timestamp">{{ago this.lastMessageTime}}</time>
          </div>

          <div class="card-metadata">
            <span class="card-phone">{{this.contactPhone}}</span>
            <span class="card-divider">·</span>
            <span class="card-msg-count">{{this.messageCount}} msgs</span>
          </div>

          <div class="card-message">{{truncate this.lastMessage 100}}</div>

          <div class="card-status in-attention">
            <span class="status-indicator in-attention"></span>
            <span>Siendo procesada</span>
          </div>
        </div>
        {{else}}
        <div class="group-empty">No hay conversaciones siendo procesadas</div>
        {{/each}}
      </div>
    </div>
    {{/if}}

    <!-- No Conversations State -->
    {{else}}
    <div class="no-conversations">
      <div class="no-conversations-icon">📭</div>
      <div class="no-conversations-text">No hay conversaciones</div>
    </div>
    {{/if}}
  </div>

  <!-- CENTER PANEL: Conversation Detail (Placeholder) -->
  <div class="panel panel-center" style="display: flex; align-items: center; justify-content: center; color: var(--text-tertiary);">
    Selecciona una conversación
  </div>

  <!-- RIGHT PANEL: Artifact Panel -->
  <aside class="panel panel-right">
    {{#if selectedArtifact}}
      <header class="artifact-header">
        <div class="artifact-header-badge">
          <span class="receptionist-working">🤖</span>
          <span class="badge-text">Working</span>
        </div>

        {{#if selectedArtifact.vehicleYear}}
          <h2 class="artifact-title">
            {{selectedArtifact.vehicleYear}}
            {{selectedArtifact.vehicleMake}}
            {{selectedArtifact.vehicleModel}}
          </h2>
        {{else}}
          <h2 class="artifact-title">Vehicle</h2>
        {{/if}}

        {{#if selectedArtifact.clientName}}
          <p class="artifact-client">{{selectedArtifact.clientName}}</p>
        {{/if}}

        {{#if selectedArtifact.clientPhone}}
          <p class="artifact-phone">{{selectedArtifact.clientPhone}}</p>
        {{/if}}
      </header>

      <!-- PHOTOS SECTION -->
      <section class="artifact-photos">
        <h3 class="artifact-section-title">Photos</h3>
        <div class="photo-grid">
          {{#each selectedArtifact.photos}}
            <div class="photo-thumbnail">
              <img src="{{this.url}}" alt="Photo {{@index}}" title="Photo {{@index}}">
            </div>
          {{else}}
            <p class="artifact-empty-section">No photos yet</p>
          {{/each}}
        </div>
      </section>

      <!-- TIMELINE SECTION -->
      <section class="artifact-timeline">
        <h3 class="artifact-section-title">Activity</h3>
        <div class="timeline">
          {{#each timelineItems}}
            <div class="timeline-item">
              <span class="timeline-icon">{{this.icon}}</span>
              <div class="timeline-content">
                <p class="timeline-description">{{this.description}}</p>
                <span class="timeline-time">{{this.time}}</span>
                {{#if this.detail}}<p class="timeline-detail">{{this.detail}}</p>{{/if}}
              </div>
            </div>
          {{else}}
            <p class="artifact-empty-section">No activity yet</p>
          {{/each}}
        </div>
      </section>

      <!-- PROGRESS SECTION -->
      <section class="artifact-progress">
        <h3 class="artifact-section-title">Progress</h3>
        <div class="progress-container">
          <div class="progress-bar">
            <div class="progress-fill" style="width: {{completionPercentage}}%;"></div>
          </div>
          <p class="progress-text">{{completedItems}}/{{totalItems}} items complete</p>
        </div>
      </section>

      <!-- ACTION BUTTONS SECTION -->
      <section class="artifact-actions">
        <button class="btn btn-primary btn-block">Approve</button>
        <button class="btn btn-secondary btn-block">Request Photos</button>
        <button class="btn btn-secondary btn-block">Transfer</button>
        <button class="btn btn-secondary btn-block">Pause</button>
      </section>
    {{else}}
      <div class="artifact-empty">
        <p>Select a conversation to view details</p>
      </div>
    {{/if}}
  </aside>
</div>
