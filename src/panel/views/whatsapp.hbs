<style>
  .whatsapp-container {
    padding: var(--spacing-2xl);
  }

  .whatsapp-title {
    font-size: var(--font-size-h1);
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
    margin-bottom: var(--spacing-2xl);
  }

  .status-section {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: var(--spacing-lg);
    margin-bottom: var(--spacing-2xl);
  }

  .status-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-md);
  }

  .status-label {
    font-size: var(--font-size-small);
    color: var(--text-secondary);
    font-weight: var(--font-weight-semibold);
  }

  .status-value {
    font-weight: var(--font-weight-semibold);
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-small);
  }

  .status-value.connected {
    background: rgba(16, 185, 129, 0.1);
    color: var(--accent-success);
  }

  .status-value.disconnected {
    background: rgba(245, 158, 11, 0.1);
    color: var(--accent-warning);
  }

  .connection-info {
    font-size: var(--font-size-small);
    color: var(--text-secondary);
    padding-top: var(--spacing-md);
    border-top: 1px solid var(--border-light);
  }

  .error-info {
    font-size: var(--font-size-small);
    color: var(--accent-danger);
    margin-top: var(--spacing-md);
  }

  .qr-section {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: var(--spacing-lg);
    margin-bottom: var(--spacing-2xl);
  }

  .qr-title {
    font-size: var(--font-size-body);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    margin-bottom: var(--spacing-lg);
  }

  .qr-instructions {
    font-size: var(--font-size-small);
    color: var(--text-secondary);
    margin-bottom: var(--spacing-lg);
  }

  .qr-image {
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: var(--spacing-md);
    background: var(--bg-secondary);
    display: inline-block;
  }

  .qr-unavailable {
    font-size: var(--font-size-small);
    color: var(--text-tertiary);
  }

  .logout-section {
    background: rgba(245, 158, 11, 0.05);
    border: 1px solid var(--accent-warning);
    border-radius: var(--radius-md);
    padding: var(--spacing-lg);
  }

  .logout-message {
    font-size: var(--font-size-small);
    color: var(--accent-warning);
  }

  .logout-message code {
    background: rgba(245, 158, 11, 0.1);
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-sm);
    font-family: 'Courier New', monospace;
  }
</style>

<div class="whatsapp-container">
  <h1 class="whatsapp-title">Estado de WhatsApp</h1>

  <section class="status-section"
           hx-get="/panel/api/whatsapp/state"
           hx-trigger="every 5s"
           hx-target="#wa-status-value"
           hx-swap="outerHTML">
    <div class="status-item">
      <span class="status-label">Estado:</span>
      <span id="wa-status-value" class="status-value {{#if (eq adapter.status "connected")}}connected{{else}}disconnected{{/if}}">
        {{adapter.status}}
      </span>
    </div>
    {{#if adapter.lastConnectedAt}}
      <div class="connection-info">Última conexión: {{date adapter.lastConnectedAt}}</div>
    {{/if}}
    {{#if adapter.lastError}}
      <div class="error-info">Último error: {{adapter.lastError}}</div>
    {{/if}}
  </section>

  {{#if (eq adapter.status "qr_required")}}
  <section class="qr-section">
    <h2 class="qr-title">Escanea el QR</h2>
    {{#if adapter.qr}}
      <p class="qr-instructions">Abre WhatsApp → Ajustes → Dispositivos vinculados → Vincular un dispositivo.</p>
      <div class="qr-image">
        <img src="https://api.qrserver.com/v1/create-qr-code/?size=300x300&data={{adapter.qr}}" alt="QR" style="display: block; border-radius: var(--radius-md);">
      </div>
    {{else}}
      <div class="qr-unavailable">QR no disponible. Revisa la terminal del proceso.</div>
    {{/if}}
  </section>
  {{/if}}

  {{#if (eq adapter.status "logged_out")}}
  <section class="logout-section">
    <p class="logout-message">
      La sesión fue cerrada desde el teléfono. Borra <code>./data/baileys-session/</code>
      y reinicia el proceso para emparejar de nuevo.
    </p>
  </section>
  {{/if}}
</div>
