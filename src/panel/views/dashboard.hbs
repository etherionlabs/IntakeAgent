<style>
  .dashboard-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--spacing-3xl);
    padding: 0 var(--spacing-2xl);
  }

  .dashboard-title {
    font-size: var(--font-size-h1);
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
  }

  .status-badge {
    padding: var(--spacing-sm) var(--spacing-md);
    border-radius: var(--radius-md);
    font-size: var(--font-size-small);
    font-weight: var(--font-weight-semibold);
  }

  .status-badge.connected {
    background: rgba(16, 185, 129, 0.1);
    color: var(--accent-success);
  }

  .status-badge.disconnected {
    background: rgba(245, 158, 11, 0.1);
    color: var(--accent-warning);
  }

  .dashboard-header-actions {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
  }

  .dashboard-link {
    color: var(--accent);
    text-decoration: none;
    font-size: var(--font-size-small);
    font-weight: var(--font-weight-semibold);
    transition: var(--transition-normal);
  }

  .dashboard-link:hover {
    opacity: 0.8;
    text-decoration: underline;
  }

  .non-intake-section {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: var(--spacing-lg);
    margin-bottom: var(--spacing-2xl);
  }

  .non-intake-title {
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    margin-bottom: var(--spacing-md);
    font-size: var(--font-size-body);
  }

  .non-intake-list {
    list-style: none;
    font-size: var(--font-size-small);
  }

  .non-intake-item {
    display: flex;
    gap: var(--spacing-md);
    padding: var(--spacing-sm) 0;
    border-bottom: 1px solid var(--border-light);
  }

  .non-intake-item:last-child {
    border-bottom: none;
  }

  .non-intake-phone {
    color: var(--text-secondary);
    font-family: monospace;
    flex-shrink: 0;
  }

  .non-intake-reason {
    color: var(--text-tertiary);
    flex: 1;
  }

  .non-intake-count {
    color: var(--text-tertiary);
    flex-shrink: 0;
  }
</style>

<div class="dashboard-header">
  <h1 class="dashboard-title">Dashboard</h1>
  <div class="dashboard-header-actions">
    <span class="status-badge {{#if (eq adapter.status "connected")}}connected{{else}}disconnected{{/if}}">
      WhatsApp: {{adapter.status}}
    </span>
    <a href="/panel/whatsapp" class="dashboard-link">detalles</a>
  </div>
</div>

{{#> jobsTable title="📥 Listos para revisar" rows=ready emptyMessage="No hay nada pendiente."}}{{/jobsTable}}
{{#> jobsTable title="💬 Intake en curso" rows=open emptyMessage="Sin intakes activos."}}{{/jobsTable}}
{{#> jobsTable title="👤 En curso (humano)" rows=inProgress emptyMessage="Nadie en curso."}}{{/jobsTable}}
{{#> jobsTable title="✅ Cerrados (últimos 20)" rows=closed emptyMessage="Sin cierres aún."}}{{/jobsTable}}

{{#if nonIntake.length}}
<section class="non-intake-section">
  <h2 class="non-intake-title">⚠️ Marcados como NO intake</h2>
  <ul class="non-intake-list">
    {{#each nonIntake}}
      <li class="non-intake-item">
        <code class="non-intake-phone">{{this.phone}}</code>
        <span class="non-intake-reason">{{this.reason}}</span>
        <span class="non-intake-count">{{this.count}} msgs</span>
      </li>
    {{/each}}
  </ul>
</section>
{{/if}}
