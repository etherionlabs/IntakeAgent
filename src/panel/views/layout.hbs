<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}} · {{businessName}}</title>
  <script src="https://unpkg.com/htmx.org@1.9.12"></script>
  <link rel="stylesheet" href="/panel/static/system.css">
  <link rel="stylesheet" href="/panel/static/layout.css">
  <link rel="stylesheet" href="/panel/static/animations.css">
  <style>
    .layout-navbar {
      background: var(--bg-primary);
      border-bottom: 1px solid var(--border-color);
      padding: var(--spacing-lg) var(--spacing-2xl);
      position: sticky;
      top: 0;
      z-index: 50;
    }

    .navbar-content {
      display: flex;
      align-items: center;
      gap: var(--spacing-2xl);
      max-width: 1200px;
      margin: 0 auto;
    }

    .navbar-brand {
      font-weight: var(--font-weight-bold);
      font-size: var(--font-size-h2);
      color: var(--text-primary);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: var(--spacing-md);
    }

    .navbar-brand:hover {
      opacity: 0.8;
    }

    .navbar-nav {
      display: flex;
      align-items: center;
      gap: var(--spacing-2xl);
      flex: 1;
    }

    .navbar-nav a {
      font-size: var(--font-size-small);
      color: var(--text-secondary);
      text-decoration: none;
      transition: var(--transition-normal);
      font-weight: var(--font-weight-normal);
    }

    .navbar-nav a:hover {
      color: var(--text-primary);
      opacity: 0.9;
    }

    .navbar-user {
      display: flex;
      align-items: center;
      gap: var(--spacing-lg);
      margin-left: auto;
      font-size: var(--font-size-small);
    }

    .navbar-username {
      color: var(--text-secondary);
      font-weight: var(--font-weight-normal);
    }

    .navbar-logout-form {
      margin: 0;
    }

    .navbar-logout-button {
      background: none;
      border: none;
      color: var(--text-secondary);
      cursor: pointer;
      font-size: var(--font-size-small);
      transition: var(--transition-normal);
      padding: 0;
      font-family: inherit;
    }

    .navbar-logout-button:hover {
      color: var(--accent-danger);
    }

    .layout-main {
      max-width: 1200px;
      margin: 0 auto;
      padding: var(--spacing-2xl) var(--spacing-lg);
    }

    @media (max-width: 768px) {
      .navbar-content {
        flex-wrap: wrap;
        gap: var(--spacing-lg);
      }

      .navbar-nav {
        order: 3;
        width: 100%;
        flex-direction: column;
        gap: var(--spacing-md);
      }

      .navbar-user {
        order: 4;
        width: 100%;
        margin-left: 0;
        justify-content: flex-end;
      }

      .layout-main {
        padding: var(--spacing-lg);
      }
    }
  </style>
</head>
<body>
  <nav class="layout-navbar">
    <div class="navbar-content">
      <a href="/panel/dashboard" class="navbar-brand">
        <span>◆</span>
        <span>{{businessName}}</span>
      </a>
      <div class="navbar-nav">
        <a href="/panel/dashboard">Dashboard</a>
        <a href="/panel/inbox">Inbox</a>
        <a href="/panel/incoming">Incoming</a>
        <a href="/panel/contacts">Contactos</a>
        <a href="/panel/whatsapp">WhatsApp</a>
        <a href="/panel/usage">Costos</a>
        <a href="/panel/settings">Settings</a>
        <a href="/panel/config">Config</a>
      </div>
      <div class="navbar-user">
        <span class="navbar-username">{{username}}</span>
        <form method="POST" action="/panel/logout" class="navbar-logout-form">
          <button type="submit" class="navbar-logout-button">Salir</button>
        </form>
      </div>
    </div>
  </nav>
  <main class="layout-main">
    {{{body}}}
  </main>
</body>
</html>
