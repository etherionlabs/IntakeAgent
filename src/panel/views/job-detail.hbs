<style>
  .job-detail-container {
    padding: var(--spacing-2xl);
  }

  .job-not-found {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: var(--spacing-3xl);
    text-align: center;
  }

  .job-not-found-text {
    color: var(--text-secondary);
    margin-bottom: var(--spacing-lg);
  }

  .back-link {
    color: var(--accent);
    text-decoration: none;
    font-size: var(--font-size-small);
    font-weight: var(--font-weight-semibold);
    transition: var(--transition-normal);
  }

  .back-link:hover {
    opacity: 0.8;
    text-decoration: underline;
  }

  .job-header {
    margin-bottom: var(--spacing-2xl);
  }

  .job-title {
    font-size: var(--font-size-h2);
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
    margin-top: var(--spacing-sm);
  }

  .job-meta {
    font-size: var(--font-size-small);
    color: var(--text-secondary);
    margin-top: var(--spacing-sm);
    display: flex;
    gap: var(--spacing-md);
    align-items: center;
  }

  .job-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: var(--spacing-lg);
  }

  .job-section {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: var(--spacing-lg);
  }

  .job-section-title {
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    margin-bottom: var(--spacing-md);
    font-size: var(--font-size-body);
  }

  .conversation-area {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    max-height: 600px;
    overflow-y: auto;
  }

  .message-bubble {
    max-width: 500px;
    padding: var(--spacing-md) var(--spacing-lg);
    border-radius: var(--radius-md);
    word-wrap: break-word;
  }

  .message-bubble.outbound {
    margin-left: auto;
    background: rgba(37, 99, 235, 0.05);
    color: var(--text-primary);
    border: 1px solid var(--accent);
  }

  .message-bubble.inbound {
    background: var(--bg-secondary);
    color: var(--text-primary);
    border: 1px solid var(--border-color);
  }

  .message-meta {
    font-size: var(--font-size-tiny);
    color: var(--text-tertiary);
    margin-bottom: var(--spacing-xs);
  }

  .message-body {
    white-space: pre-wrap;
    font-size: var(--font-size-small);
  }

  .message-media {
    font-size: var(--font-size-tiny);
    color: var(--text-tertiary);
    margin-top: var(--spacing-xs);
  }

  .sidebar-section {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: var(--spacing-lg);
    margin-bottom: var(--spacing-lg);
  }

  .form-section {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .form-fieldset {
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: var(--spacing-md);
  }

  .form-legend {
    font-size: var(--font-size-tiny);
    font-weight: var(--font-weight-semibold);
    color: var(--text-secondary);
    text-transform: uppercase;
    padding: 0 var(--spacing-sm);
  }

  .form-field {
    margin-bottom: var(--spacing-md);
  }

  .form-field:last-child {
    margin-bottom: 0;
  }

  .form-label {
    display: block;
    font-size: var(--font-size-small);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    margin-bottom: var(--spacing-sm);
  }

  .form-label .required {
    color: var(--accent-danger);
  }

  .form-input,
  .form-select,
  .form-textarea {
    width: 100%;
    padding: var(--spacing-md) var(--spacing-lg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    font-size: var(--font-size-small);
    background: var(--bg-secondary);
    color: var(--text-primary);
    transition: var(--transition-normal);
    font-family: inherit;
  }

  .form-input:focus,
  .form-select:focus,
  .form-textarea:focus {
    outline: none;
    border-color: var(--accent);
    background: var(--bg-primary);
    box-shadow: var(--focus-ring);
  }

  .form-textarea {
    min-height: 80px;
    resize: vertical;
  }

  .form-declined-note {
    font-size: var(--font-size-tiny);
    color: var(--accent-warning);
    margin-top: var(--spacing-xs);
  }

  .form-buttons {
    display: flex;
    gap: var(--spacing-md);
    margin-top: var(--spacing-lg);
  }

  .actions-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-md);
  }

  .action-button {
    padding: var(--spacing-md) var(--spacing-lg);
    border: none;
    border-radius: var(--radius-md);
    font-size: var(--font-size-small);
    font-weight: var(--font-weight-semibold);
    cursor: pointer;
    transition: var(--transition-normal);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .action-button.primary {
    background: linear-gradient(135deg, var(--brand-primary) 0%, var(--brand-secondary) 100%);
    color: white;
    box-shadow: var(--shadow-sm);
  }

  .action-button.primary:hover {
    box-shadow: var(--shadow-lg);
    opacity: 0.95;
  }

  .action-button.secondary {
    background: var(--bg-secondary);
    color: var(--text-primary);
    border: 1px solid var(--border-color);
  }

  .action-button.secondary:hover {
    background: var(--bg-tertiary);
  }

  .action-button.warning {
    background: rgba(245, 158, 11, 0.1);
    color: var(--accent-warning);
    border: 1px solid var(--accent-warning);
  }

  .action-button.warning:hover {
    background: rgba(245, 158, 11, 0.2);
  }

  .action-button.success {
    background: rgba(16, 185, 129, 0.1);
    color: var(--accent-success);
    border: 1px solid var(--accent-success);
  }

  .action-button.success:hover {
    background: rgba(16, 185, 129, 0.2);
  }

  .action-button.danger {
    background: rgba(220, 38, 38, 0.1);
    color: var(--accent-danger);
    border: 1px solid var(--accent-danger);
  }

  .action-button.danger:hover {
    background: rgba(220, 38, 38, 0.2);
  }

  .bot-status {
    font-size: var(--font-size-tiny);
    color: var(--text-tertiary);
    margin-top: var(--spacing-md);
    padding-top: var(--spacing-md);
    border-top: 1px solid var(--border-light);
  }

  .notes-list {
    font-size: var(--font-size-small);
    color: var(--text-secondary);
    list-style-position: inside;
  }

  .notes-list li {
    padding: var(--spacing-xs) 0;
  }

  .other-jobs-list {
    font-size: var(--font-size-small);
    list-style: none;
  }

  .other-jobs-item {
    padding: var(--spacing-sm) 0;
    border-bottom: 1px solid var(--border-light);
  }

  .other-jobs-item:last-child {
    border-bottom: none;
  }

  .other-jobs-link {
    color: var(--accent);
    text-decoration: none;
    transition: var(--transition-normal);
  }

  .other-jobs-link:hover {
    opacity: 0.8;
    text-decoration: underline;
  }

  .agent-runs-list {
    font-size: var(--font-size-tiny);
    color: var(--text-secondary);
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .agent-run-error {
    color: var(--accent-danger);
  }

  @media (max-width: 1200px) {
    .job-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="job-detail-container">
  {{#if notFound}}
    <div class="job-not-found">
      <p class="job-not-found-text">No se encontró ese job.</p>
      <a href="/panel/dashboard" class="back-link">← volver al dashboard</a>
    </div>
  {{else}}

  <div class="job-header">
    <a href="/panel/dashboard" class="back-link">← dashboard</a>
    <h1 class="job-title">
      {{#if intake.client.name.value}}{{intake.client.name.value}}{{else}}{{contact.phoneE164}}{{/if}}
    </h1>
    <div class="text-sm text-gray-500">
      {{contact.phoneE164}} ·
      <span class="job-status-badge {{statusClass job.status}}">{{statusLabel job.status}}</span>
      · abierto {{ago job.openedAt}}
    </div>
  </div>

  <div class="job-grid">
    <!-- Messages Section -->
    <section class="job-section">
      <h2 class="job-section-title">Conversación ({{messages.length}})</h2>
      <div class="conversation-area">
        {{#each messages}}
          <div class="message-bubble {{#if (eq this.direction "outbound")}}outbound{{else}}inbound{{/if}}">
            <div class="message-meta">
              {{#if (eq this.direction "outbound")}}bot{{else}}cliente{{/if}} · {{date this.createdAt}}
            </div>
            {{#if this.body}}
              <div class="message-body">{{this.body}}</div>
            {{else}}
              <div style="color: var(--text-tertiary); font-style: italic;">({{this.kind}})</div>
            {{/if}}
            {{#if this.mediaPath}}
              <div class="message-media">📎 {{this.mediaPath}}</div>
            {{/if}}
          </div>
        {{/each}}
      </div>
    </section>

    <!-- Sidebar -->
    <aside>
      <!-- Intake Form -->
      <section class="sidebar-section">
        <h2 class="job-section-title">Datos del intake</h2>
        <form hx-patch="/panel/api/jobs/{{job.id}}/intake" hx-swap="outerHTML" class="form-section">
          {{#each schema.sections}}
            <fieldset class="form-fieldset">
              <legend class="form-legend">{{this.label}}</legend>
              {{#each this.fields}}
                {{#with (lookup (lookup ../../intake ../key) this.key)}}
                <div class="form-field">
                  <label class="form-label">
                    {{../this.label}}
                    {{#if ../this.required}}<span class="required">*</span>{{/if}}
                    {{#if this.declined}}<span style="color: var(--accent-warning);">(declinado)</span>{{/if}}
                  </label>
                  {{#if (eq ../this.type "boolean")}}
                    <select name="{{../../key}}.{{../this.key}}" class="form-select">
                      <option value="">—</option>
                      <option value="true" {{#if (eq this.value true)}}selected{{/if}}>Sí</option>
                      <option value="false" {{#if (eq this.value false)}}selected{{/if}}>No</option>
                    </select>
                  {{else if (eq ../this.type "enum")}}
                    <select name="{{../../key}}.{{../this.key}}" class="form-select">
                      <option value="">—</option>
                      {{#each ../this.options}}
                        <option value="{{this}}" {{#if (eq this ../this.value)}}selected{{/if}}>{{this}}</option>
                      {{/each}}
                    </select>
                  {{else if (eq ../this.type "text")}}
                    <textarea name="{{../../key}}.{{../this.key}}" rows="2" class="form-textarea">{{this.value}}</textarea>
                  {{else}}
                    <input type="{{#if (eq ../this.type "integer")}}number{{else if (eq ../this.type "number")}}number{{else if (eq ../this.type "phone")}}tel{{else if (eq ../this.type "date")}}date{{else}}text{{/if}}"
                           name="{{../../key}}.{{../this.key}}"
                           value="{{this.value}}"
                           class="form-input">
                  {{/if}}
                  {{#if this.declined_reason}}
                    <div class="form-declined-note">Razón declined: {{this.declined_reason}}</div>
                  {{/if}}
                </div>
                {{/with}}
              {{/each}}
            </fieldset>
          {{/each}}
          {{#if intake.free_notes.length}}
            <fieldset class="form-fieldset">
              <legend class="form-legend">Notas libres</legend>
              <ul class="notes-list">
                {{#each intake.free_notes}}
                  <li>{{this.text}}</li>
                {{/each}}
              </ul>
            </fieldset>
          {{/if}}
          <div class="form-buttons">
            <button type="submit" class="btn btn-primary">Guardar cambios</button>
            <a href="/panel/jobs/{{job.id}}" class="btn btn-secondary">Cancelar</a>
          </div>
        </form>
      </section>

      <!-- Actions -->
      <section class="sidebar-section">
        <h2 class="job-section-title">Acciones</h2>
        <div class="actions-list">
          <form hx-post="/panel/api/contacts/{{contact.id}}/bot-toggle" hx-swap="none" style="margin: 0;">
            {{#if contact.botActive}}
              <button type="submit" class="action-button warning">⏸ Pausar bot</button>
            {{else}}
              <button type="submit" class="action-button success">▶ Reanudar bot</button>
            {{/if}}
          </form>

          {{#if (eq job.status "READY_FOR_REVIEW")}}
            <form hx-post="/panel/api/jobs/{{job.id}}/status" hx-swap="none" style="margin: 0;">
              <input type="hidden" name="status" value="IN_PROGRESS">
              <button type="submit" class="action-button primary">👤 Tomar caso</button>
            </form>
          {{/if}}

          {{#unless (eq job.status "CLOSED")}}
            <form hx-post="/panel/api/jobs/{{job.id}}/status" hx-swap="none"
                  hx-confirm="¿Cerrar este job?" style="margin: 0;">
              <input type="hidden" name="status" value="CLOSED">
              <button type="submit" class="action-button secondary">✓ Cerrar</button>
            </form>
          {{/unless}}

          {{#if (eq job.status "CLOSED")}}
            <form hx-post="/panel/api/jobs/{{job.id}}/status" hx-swap="none" style="margin: 0;">
              <input type="hidden" name="status" value="OPEN_INTAKE">
              <button type="submit" class="action-button primary">↩ Reabrir</button>
            </form>
          {{/if}}
        </div>
        <div class="bot-status">
          Bot {{#if contact.botActive}}activo{{else}}pausado{{/if}} para este contacto.
          {{#if contact.flaggedNonIntake}}<span style="color: var(--accent-danger);">· Flagged: {{contact.flaggedReason}}</span>{{/if}}
        </div>
      </section>

      <!-- Other Jobs -->
      <section class="sidebar-section">
        <h2 class="job-section-title">Otros jobs del contacto</h2>
        {{#if otherJobs.length}}
          <ul class="other-jobs-list">
            {{#each otherJobs}}
              <li class="other-jobs-item">
                <a href="/panel/jobs/{{this.id}}" class="other-jobs-link">
                  {{statusLabel this.status}} · {{ago this.openedAt}}
                </a>
              </li>
            {{/each}}
          </ul>
        {{else}}
          <div style="font-size: var(--font-size-small); color: var(--text-tertiary);">Sin otros jobs.</div>
        {{/if}}
      </section>

      <!-- Agent Runs -->
      {{#if agentRuns.length}}
      <section class="sidebar-section">
        <h2 class="job-section-title">Últimos agent runs</h2>
        <ul class="agent-runs-list">
          {{#each agentRuns}}
            <li>
              {{date this.createdAt}} · {{this.model}} · tokens {{this.inputTokens}}/{{this.outputTokens}}
              {{#if this.error}}<span class="agent-run-error">· {{truncate this.error 60}}</span>{{/if}}
            </li>
          {{/each}}
        </ul>
      </section>
      {{/if}}
    </aside>
  </div>

{{/if}}
