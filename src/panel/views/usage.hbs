<style>
  .usage-container {
    padding: var(--spacing-2xl);
  }

  .usage-title {
    font-size: var(--font-size-h1);
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
    margin-bottom: var(--spacing-2xl);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-3xl);
  }

  .stat-card {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: var(--spacing-lg);
    box-shadow: var(--shadow-sm);
  }

  .stat-label {
    font-size: var(--font-size-tiny);
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: var(--font-weight-semibold);
  }

  .stat-value {
    font-size: 28px;
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
    margin-top: var(--spacing-sm);
  }

  .stat-value.error {
    color: var(--accent-danger);
  }

  .stat-detail {
    font-size: var(--font-size-tiny);
    color: var(--text-secondary);
    margin-top: var(--spacing-sm);
  }

  .runs-section {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: var(--spacing-lg);
  }

  .runs-title {
    font-size: var(--font-size-body);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    margin-bottom: var(--spacing-lg);
  }

  .runs-table {
    width: 100%;
    border-collapse: collapse;
  }

  .runs-table thead {
    border-bottom: 1px solid var(--border-color);
  }

  .runs-table th {
    padding: var(--spacing-md);
    text-align: left;
    font-size: var(--font-size-small);
    font-weight: var(--font-weight-semibold);
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .runs-table th.text-right {
    text-align: right;
  }

  .runs-table tbody tr {
    border-top: 1px solid var(--border-light);
    transition: var(--transition-normal);
  }

  .runs-table tbody tr:hover {
    background: var(--bg-secondary);
  }

  .runs-table td {
    padding: var(--spacing-md);
    font-size: var(--font-size-small);
    color: var(--text-secondary);
  }

  .runs-table td.text-right {
    text-align: right;
  }

  .contact-link {
    color: var(--accent);
    text-decoration: none;
    transition: var(--transition-normal);
  }

  .contact-link:hover {
    opacity: 0.8;
    text-decoration: underline;
  }

  .error-text {
    color: var(--accent-danger);
    font-size: var(--font-size-tiny);
  }

  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }

    .runs-table {
      font-size: var(--font-size-tiny);
    }

    .runs-table th,
    .runs-table td {
      padding: var(--spacing-sm);
    }
  }
</style>

<div class="usage-container">
  <h1 class="usage-title">Costos y uso</h1>

  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-label">Este mes</div>
      <div class="stat-value">${{month.costUsd}}</div>
      <div class="stat-detail">{{month.runs}} runs · {{month.inputTokens}} in / {{month.outputTokens}} out</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Hoy</div>
      <div class="stat-value">${{today.costUsd}}</div>
      <div class="stat-detail">{{today.runs}} runs · {{today.inputTokens}} in / {{today.outputTokens}} out</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Errores del mes</div>
      <div class="stat-value {{#if errorsThisMonth}}error{{/if}}">{{errorsThisMonth}}</div>
    </div>
  </div>

  <section class="runs-section">
    <h2 class="runs-title">Últimos 30 agent runs</h2>
    <table class="runs-table">
      <thead>
        <tr>
          <th>Hora</th>
          <th>Contacto</th>
          <th>Modelo</th>
          <th class="text-right">Tokens</th>
          <th class="text-right">Costo</th>
          <th>Error</th>
        </tr>
      </thead>
      <tbody>
        {{#each recent}}
          <tr>
            <td>{{date this.createdAt}}</td>
            <td><a href="/panel/jobs/{{this.jobId}}" class="contact-link">{{this.job.contact.phoneE164}}</a></td>
            <td>{{this.model}}</td>
            <td class="text-right">{{this.inputTokens}}/{{this.outputTokens}}</td>
            <td class="text-right">{{#if this.costUsd}}${{this.costUsd}}{{else}}—{{/if}}</td>
            <td class="{{#if this.error}}error-text{{/if}}">{{truncate this.error 50}}</td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </section>
</div>
