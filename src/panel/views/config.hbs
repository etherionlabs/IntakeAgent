<style>
  .config-container {
    padding: var(--spacing-2xl);
  }

  .config-title {
    font-size: var(--font-size-h1);
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
    margin-bottom: var(--spacing-lg);
  }

  .config-note {
    font-size: var(--font-size-small);
    color: var(--text-secondary);
    margin-bottom: var(--spacing-2xl);
    padding: var(--spacing-lg);
    background: var(--bg-secondary);
    border-radius: var(--radius-md);
  }

  .config-section {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    margin-bottom: var(--spacing-2xl);
  }

  .config-details {
    padding: var(--spacing-lg);
  }

  .config-details summary {
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    cursor: pointer;
    padding: var(--spacing-md);
    margin: calc(var(--spacing-lg) * -1);
    margin-bottom: var(--spacing-lg);
    border-radius: var(--radius-md);
    transition: var(--transition-normal);
    user-select: none;
  }

  .config-details summary:hover {
    background: var(--bg-secondary);
  }

  .config-details summary::-webkit-details-marker {
    color: var(--accent);
  }

  .config-json {
    font-size: var(--font-size-tiny);
    background: var(--bg-secondary);
    color: var(--text-primary);
    padding: var(--spacing-lg);
    border-radius: var(--radius-md);
    margin-top: var(--spacing-md);
    overflow-x: auto;
    border: 1px solid var(--border-light);
    font-family: 'Courier New', monospace;
    line-height: var(--line-height-tight);
  }
</style>

<div class="config-container">
  <h1 class="config-title">Configuración (solo lectura)</h1>

  <p class="config-note">
    Edita los archivos en disco (<code>config.json</code> y <code>profiles/.../</code>) y reinicia
    el proceso para aplicar cambios.
  </p>

  <details class="config-section" open>
    <summary>config.json</summary>
    <pre class="config-json">{{json config}}</pre>
  </details>

  <details class="config-section">
    <summary>intake-schema.json ({{schema.$businessName}})</summary>
    <pre class="config-json">{{json schema}}</pre>
  </details>

  <details class="config-section">
    <summary>prompt-vars.json</summary>
    <pre class="config-json">{{json promptVars}}</pre>
  </details>

  <details class="config-section">
    <summary>business-facts.json</summary>
    <pre class="config-json">{{json facts}}</pre>
  </details>

  <details class="config-section">
    <summary>welcome.txt</summary>
    <pre class="config-json">{{welcome}}</pre>
  </details>
</div>
