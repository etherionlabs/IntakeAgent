<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}} · {{businessName}}</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/htmx.org@1.9.12"></script>
  <link rel="stylesheet" href="/panel/static/system.css">
  <link rel="stylesheet" href="/panel/static/layout.css">
  <link rel="stylesheet" href="/panel/static/animations.css">
  <link rel="stylesheet" href="/panel/static/inbox.css">
  <link rel="stylesheet" href="/panel/static/incoming.css">
  <link rel="stylesheet" href="/panel/static/settings.css">
  <style>
    /* CSS variables are defined in system.css and loaded above */
    body {
      margin: 0;
      padding: 0;
    }

    * {
      box-sizing: border-box;
    }
  </style>
</head>
<body>
  <div class="container">
    <aside class="sidebar">
      <div class="sidebar-logo" title="Home">◆</div>
      <nav class="sidebar-nav">
        <a href="/panel/inbox" class="nav-item {{#if (eq currentPage 'inbox')}}active{{/if}}" title="Inbox">📥</a>
        <a href="/panel/incoming" class="nav-item {{#if (eq currentPage 'incoming')}}active{{/if}}" title="Incoming">📊</a>
        <a href="/panel/settings" class="nav-item {{#if (eq currentPage 'settings')}}active{{/if}}" title="Settings">⚙️</a>
      </nav>
      <div class="sidebar-bottom">
        <div class="avatar" title="User menu">{{userInitials}}</div>
      </div>
    </aside>
    <main class="main-content">
      {{{body}}}
    </main>
  </div>
</body>
</html>
