# OpenRouter — modelos de chat para el agente + transcripción Whisper vía
# /audio/transcriptions. Una sola key cubre ambos.
OPENROUTER_API_KEY=sk-or-...

# Panel auth — hash bcrypt de la contraseña del panel.
# Generar con:  npm run panel:hash -- <tu-password>
PANEL_PASSWORD_HASH=

# Secreto para firmar las sesiones del panel (HMAC). DEBE ser estable:
# si cambia, todos los usuarios del panel quedan deslogueados.
# Generar uno aleatorio (32+ bytes). El instalador lo hace por ti.
PANEL_SESSION_SECRET=

# Puerto del panel web (opcional, por defecto 3000).
PANEL_PORT=3000

# Database
DATABASE_URL="file:./data/intake.db"
