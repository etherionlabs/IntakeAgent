# OpenRouter — modelos de chat para el agente
OPENROUTER_API_KEY=sk-or-...

# OpenAI — Whisper para transcripción de audio (OpenRouter NO ofrece Whisper).
# Opcional. Sin esta key los audios llegan sin transcribir y el agente pide
# texto al cliente.
OPENAI_API_KEY=

# Panel auth (se usa en Plan 5)
PANEL_PASSWORD_HASH=

# Database
DATABASE_URL="file:./data/intake.db"
