# PostgreSQL (solo red interna Docker — nunca expuesto)
POSTGRES_PASSWORD=change-me-strong

# Token del endpoint interno worker↔api (defensa en profundidad)
INTERNAL_API_TOKEN=change-me-internal-token

# OpenRouter (LLM + Whisper)
OPENROUTER_API_KEY=sk-or-v1-...

# Sharding del worker multi-tenant (TenantManager). Default: 1 shard atiende a
# todos los tenants. Para escalar, subir réplicas: cada una con su SHARD_ID
# (0..N-1) y el mismo SHARD_COUNT=N. La API usa SHARD_COUNT para rutear.
SHARD_ID=0
SHARD_COUNT=1
# Agregar un tenant ya NO requiere variables aquí: se da de alta en la BD
# (Tenant + TenantSettings) y el TenantManager lo levanta sin reiniciar.

# JWT del panel (API Central)
JWT_SECRET=change-me-jwt-secret

# Origen(es) CORS permitido(s) — URL(s) del panel, separadas por coma.
# En producción NO puede ser "*" (las cookies cross-site lo prohíben).
CORS_ORIGIN=https://<tu-sitio>.netlify.app

# Longitud mínima de contraseña del panel (política de auth). Opcional, def. 10.
# MIN_PASSWORD_LENGTH=10

# --- Billing (Fase 3) — Stripe. NO commitear valores reales. ---
# Claves del dashboard de Stripe (modo test/prod). Secretas: solo backend.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# price_… del Product/Price recurrente creado en Stripe (espejado en la tabla Plan).
STRIPE_PRICE_ID=price_...
# Días de gracia en past_due antes de bloquear (def. 3).
BILLING_GRACE_DAYS=3
# Tenants exentos de cobro (CSV de tenantIds). Bypass temporal del piloto.
# BILLING_EXEMPT_TENANT_IDS=
